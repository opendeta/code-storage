{"fileName":"Link to Website Updater! (For GitHub)","codeType":"HTML","content":"<!DOCTYPE html>\n<html lang=\"bn\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>opendeta | Pro Site Updater</title>\n    <script src=\"https://cdn.tailwindcss.com\"></script>\n    <style>\n        body { background-color: #0d1117; color: #c9d1d9; font-family: 'Segoe UI', sans-serif; }\n        .progress-container { width: 100%; background: #30363d; height: 12px; border-radius: 6px; overflow: hidden; }\n        .progress-bar { height: 100%; background: #00d1b2; width: 0%; transition: width 0.8s ease-in-out; box-shadow: 0 0 15px rgba(0, 209, 178, 0.5); }\n        .spin { animation: spin 1s linear infinite; }\n        @keyframes spin { from { transform: rotate(0deg); } to { transform: rotate(360deg); } }\n    </style>\n</head>\n<body class=\"min-h-screen flex items-center justify-center p-6\">\n\n    <div class=\"max-w-md w-full\">\n        <div id=\"main-card\" class=\"bg-[#161b22] p-8 rounded-3xl border border-[#30363d] shadow-2xl text-center\">\n            <h1 class=\"text-4xl font-black text-[#00d1b2] mb-2 italic\">opendeta</h1>\n            <p class=\"text-[10px] tracking-[4px] uppercase text-gray-500 mb-8 font-bold\">Safe Update Engine</p>\n\n            <div class=\"space-y-5\">\n                <input type=\"text\" id=\"siteLink\" class=\"w-full bg-[#0d1117] border border-[#30363d] p-4 rounded-xl text-white outline-none focus:border-[#00d1b2] text-center\" placeholder=\"আপনার সাইটের লিঙ্ক দিন\">\n                \n                <div class=\"relative\">\n                    <input type=\"file\" id=\"fileInput\" class=\"hidden\" accept=\".html\" onchange=\"updateLabel()\">\n                    <button onclick=\"document.getElementById('fileInput').click()\" class=\"w-full bg-[#0d1117] border-2 border-dashed border-[#30363d] p-6 rounded-2xl text-gray-400 hover:border-[#00d1b2] transition\">\n                        <span id=\"fileName\">নতুন HTML ফাইল দিন</span>\n                    </button>\n                </div>\n\n                <button onclick=\"processUpdate()\" class=\"w-full bg-[#00d1b2] text-black font-black py-4 rounded-xl hover:bg-white transition shadow-lg text-lg\">\n                    UPDATE THIS SITE\n                </button>\n            </div>\n        </div>\n\n        <div id=\"loader\" class=\"hidden bg-[#161b22] p-10 rounded-3xl border border-[#30363d] text-center shadow-2xl\">\n            <div class=\"flex justify-center mb-6\">\n                <svg class=\"spin h-14 w-14 text-[#00d1b2]\" viewBox=\"0 0 24 24\">\n                    <circle class=\"opacity-25\" cx=\"12\" cy=\"12\" r=\"10\" stroke=\"currentColor\" stroke-width=\"4\"></circle>\n                    <path class=\"opacity-75\" fill=\"currentColor\" d=\"M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z\"></path>\n                </svg>\n            </div>\n            <div class=\"progress-container mb-4\">\n                <div id=\"bar\" class=\"progress-bar\"></div>\n            </div>\n            <p id=\"status\" class=\"text-xl font-bold text-[#00d1b2]\">Updating Site...</p>\n            <p id=\"percent\" class=\"text-sm font-mono text-gray-500 mt-2\">0% Completed</p>\n        </div>\n    </div>\n\n    <script>\n        const TOKEN = \"Your_Token_Here(PAT)\"; \n        const USER = \"Your_GitHub_User_Name\"; \n\n        function updateLabel() {\n            const file = document.getElementById('fileInput').files[0];\n            if (file) document.getElementById('fileName').innerText = file.name;\n        }\n\n        async function processUpdate() {\n            const link = document.getElementById('siteLink').value.trim();\n            const file = document.getElementById('fileInput').files[0];\n\n            if (!link || !file) return alert(\"লিঙ্ক এবং ফাইল দুইটাই দিন!\");\n\n            // লিঙ্ক থেকে রিপোজিটরির নাম বের করার লজিক\n            let repoName;\n            try {\n                const cleanLink = link.replace(/\\/$/, \"\"); // শেষের স্ল্যাশ সরানো\n                const urlParts = cleanLink.split(\"/\");\n                repoName = urlParts.pop(); // শেষ অংশটিই রিপো নেম\n                if (repoName.includes(\"github.io\")) {\n                    repoName = urlParts.pop(); // যদি লিঙ্ক github.io তে শেষ হয় তবে তার আগের অংশ নেবে\n                }\n            } catch (e) {\n                return alert(\"Link isn't Correct!\");\n            }\n\n            document.getElementById('main-card').classList.add('hidden');\n            document.getElementById('loader').classList.remove('hidden');\n\n            try {\n                updateUI(10, \"Updating Site...\", \"10%\");\n\n                // ফাইল রিড করা\n                const reader = new FileReader();\n                const base64Content = await new Promise((resolve) => {\n                    reader.onload = () => resolve(reader.result.split(',')[1]);\n                    reader.readAsDataURL(file);\n                });\n\n                // ১. SHA আইডি খুঁজে বের করা (সবচেয়ে গুরুত্বপূর্ণ ধাপ)\n                updateUI(20, \"Updating Site...\", \"20%\");\n                const res = await fetch(`https://api.github.com/repos/${USER}/${repoName}/contents/index.html`, {\n                    headers: { 'Authorization': `token ${TOKEN}` }\n                });\n                \n                if (!res.ok) throw new Error(\"Repository-তে index.html ফাইলটি খুঁজে পাওয়া যায়নি!\");\n                const data = await res.json();\n                const sha = data.sha;\n\n                // ২. গিটহাবে আপডেট পুশ করা\n                updateUI(40, \"Updating Site...\", \"40%\");\n                const updateRes = await fetch(`https://api.github.com/repos/${USER}/${repoName}/contents/index.html`, {\n                    method: 'PUT',\n                    headers: { \n                        'Authorization': `token ${TOKEN}`,\n                        'Content-Type': 'application/json'\n                    },\n                    body: JSON.stringify({ \n                        message: \"Site Updated via opendeta Engine\", \n                        content: base64Content, \n                        sha: sha \n                    })\n                });\n\n                if (!updateRes.ok) throw new Error(\"GitHub API-তে ফাইল পাঠাতে সমস্যা হয়েছে!\");\n\n                // ৩. ৪০ সেকেন্ডের ফেইক প্রসেস (সার্ভার রিফ্রেশের জন্য)\n                const waitSteps = [60, 80, 95];\n                for (let p of waitSteps) {\n                    await new Promise(r => setTimeout(r, 12000)); \n                    updateUI(p, \"Updating Site...\", p + \"%\");\n                }\n\n                updateUI(100, \"Successfully ✅\", \"100%\");\n                \n                // ৪. আপডেট হওয়া সাইটে রিডাইরেক্ট\n                setTimeout(() => {\n                    window.location.href = link.startsWith('http') ? link : `https://${link}`;\n                }, 1500);\n\n            } catch (err) {\n                alert(\"ভুল: \" + err.message);\n                location.reload();\n            }\n        }\n\n        function updateUI(p, m, pr) {\n            document.getElementById('bar').style.width = p + \"%\";\n            document.getElementById('status').innerText = m;\n            document.getElementById('percent').innerText = pr + \" Completed\";\n        }\n    </script>\n</body>\n</html>"}