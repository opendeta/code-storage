{"fileName":"Website Builder, using GitHub (For Free & Unlimited","codeType":"HTML","content":"<!DOCTYPE html>\n<html lang=\"bn\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>opendeta | Pro Host</title>\n    <script src=\"https://cdn.tailwindcss.com\"></script>\n    <style>\n        body { background-color: #0d1117; color: #c9d1d9; font-family: 'Segoe UI', sans-serif; }\n        .progress-container { width: 100%; background: #30363d; height: 12px; border-radius: 6px; overflow: hidden; }\n        .progress-bar { height: 100%; background: #00d1b2; width: 0%; transition: width 0.8s ease-in-out; box-shadow: 0 0 15px rgba(0, 209, 178, 0.5); }\n        .custom-scroll::-webkit-scrollbar { width: 5px; }\n        .custom-scroll::-webkit-scrollbar-thumb { background: #30363d; border-radius: 10px; }\n        .spin { animation: spin 1s linear infinite; }\n        @keyframes spin { from { transform: rotate(0deg); } to { transform: rotate(360deg); } }\n        .status-fade { animation: fadeIn 0.5s ease-in-out; }\n        @keyframes fadeIn { from { opacity: 0; transform: translateY(5px); } to { opacity: 1; transform: translateY(0); } }\n    </style>\n</head>\n<body class=\"min-h-screen p-4 md:p-10\">\n\n    <div class=\"max-w-6xl mx-auto grid grid-cols-1 lg:grid-cols-2 gap-10\">\n        <div class=\"bg-[#161b22] p-8 rounded-3xl border border-[#30363d] shadow-2xl text-center\">\n            <h1 class=\"text-4xl font-black text-[#00d1b2] mb-2 italic\">opendeta</h1>\n            <p class=\"text-[10px] tracking-[4px] uppercase text-gray-500 mb-8 font-bold\">Pro Status Deployment</p>\n\n            <div id=\"upload-box\" class=\"border-2 border-dashed border-[#30363d] rounded-2xl p-10 cursor-pointer bg-[#0d1117] hover:border-[#00d1b2] transition\" onclick=\"document.getElementById('fileInput').click()\">\n                <img src=\"https://img.icons8.com/fluency/96/html-5.png\" class=\"mx-auto w-16 mb-4\">\n                <p class=\"text-sm font-bold text-gray-400\">Select HTML File</p>\n                <input type=\"file\" id=\"fileInput\" class=\"hidden\" accept=\".html\" onchange=\"showNaming()\">\n            </div>\n\n            <div id=\"naming-box\" class=\"hidden mt-6 space-y-4\">\n                <input type=\"text\" id=\"repoName\" class=\"w-full bg-[#0d1117] border border-[#30363d] p-4 rounded-xl text-white text-center text-lg outline-none focus:border-[#00d1b2]\" placeholder=\"Project Name\">\n                <button onclick=\"deployNow()\" class=\"w-full bg-[#00d1b2] text-black font-black py-4 rounded-xl hover:bg-white transition shadow-lg\">🚀 START DEPLOYING</button>\n            </div>\n\n            <div id=\"loader\" class=\"hidden mt-10\">\n                <div class=\"flex items-center justify-center mb-6\">\n                    <svg id=\"loading-icon\" class=\"spin h-12 w-12 text-[#00d1b2]\" xmlns=\"http://www.w3.org/2000/svg\" fill=\"none\" viewBox=\"0 0 24 24\"><circle class=\"opacity-25\" cx=\"12\" cy=\"12\" r=\"10\" stroke=\"currentColor\" stroke-width=\"4\"></circle><path class=\"opacity-75\" fill=\"currentColor\" d=\"M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z\"></path></svg>\n                </div>\n                <div class=\"progress-container mb-4\">\n                    <div id=\"bar\" class=\"progress-bar\"></div>\n                </div>\n                <p id=\"status\" class=\"status-fade text-lg font-bold text-[#00d1b2] mb-1\">Sending Code...</p>\n                <p id=\"percent\" class=\"text-sm font-mono text-gray-500\">0% Completed</p>\n            </div>\n        </div>\n\n        <div class=\"bg-[#161b22] p-8 rounded-3xl border border-[#30363d] shadow-2xl\">\n            <h2 class=\"text-xl font-bold mb-6 flex justify-between items-center italic\">\n                <span>📂 Deployment History</span>\n                <button onclick=\"clearHistory()\" class=\"text-[9px] text-red-400 border border-red-900 px-2 py-1 rounded hover:bg-red-900/10\">CLEAR ALL</button>\n            </h2>\n            <div id=\"siteList\" class=\"space-y-4 overflow-y-auto max-h-[480px] pr-2 custom-scroll\">\n                </div>\n        </div>\n    </div>\n\n    <script>\n        const TOKEN = \"Your_GitHub_Token(PAT\"; \n        const USER = \"Your_GitHub_User_Name\"; \n\n        window.onload = loadSites;\n\n        function showNaming() {\n            const file = document.getElementById('fileInput').files[0];\n            if (file) {\n                document.getElementById('upload-box').classList.add('hidden');\n                document.getElementById('naming-box').classList.remove('hidden');\n                document.getElementById('repoName').value = file.name.replace(\".html\", \"\").toLowerCase().replace(/\\s+/g, '-');\n            }\n        }\n\n        async function deployNow() {\n            const file = document.getElementById('fileInput').files[0];\n            const repo = document.getElementById('repoName').value.trim();\n            if (!repo) return alert(\"নাম দিন!\");\n\n            document.getElementById('naming-box').classList.add('hidden');\n            document.getElementById('loader').classList.remove('hidden');\n\n            try {\n                // ১. স্ট্যাটাস: Sending Code (১০%)\n                updateProgress(10, \"Sending Code...\", \"10%\");\n                await fetch(`https://api.github.com/user/repos`, {\n                    method: 'POST',\n                    headers: { 'Authorization': `token ${TOKEN}`, 'Content-Type': 'application/json' },\n                    body: JSON.stringify({ name: repo, auto_init: true })\n                });\n\n                // ২. স্ট্যাটাস: Deploying Website (৩০%)\n                updateProgress(30, \"Deploying Website...\", \"30%\");\n                const reader = new FileReader();\n                const content = await new Promise(r => {\n                    reader.onload = () => r(reader.result.split(',')[1]);\n                    reader.readAsDataURL(file);\n                });\n\n                await fetch(`https://api.github.com/repos/${USER}/${repo}/contents/index.html`, {\n                    method: 'PUT',\n                    headers: { 'Authorization': `token ${TOKEN}`, 'Content-Type': 'application/json' },\n                    body: JSON.stringify({ message: \"Initial commit\", content: content })\n                });\n\n                // ৩. স্ট্যাটাস: Connecting to GitHub (৫০%)\n                updateProgress(50, \"Connecting to GitHub...\", \"50%\");\n                await fetch(`https://api.github.com/repos/${USER}/${repo}/pages`, {\n                    method: 'POST',\n                    headers: { 'Authorization': `token ${TOKEN}`, 'Accept': 'application/vnd.github.switcheroo-alpha+json' },\n                    body: JSON.stringify({ source: { branch: 'main', path: '/' } })\n                });\n\n                // ৪. স্ট্যাটাস: Deploying to Live (৭০%) - এখানে আমরা সময় কাটাবো\n                const siteUrl = `https://${USER}.github.io/${repo}/`;\n                await runFakeSteps(repo, siteUrl);\n\n            } catch (err) {\n                alert(\"Error! Check token or repo name.\");\n                location.reload();\n            }\n        }\n\n        function updateProgress(p, msg, perc) {\n            document.getElementById('bar').style.width = p + \"%\";\n            document.getElementById('status').innerText = msg;\n            document.getElementById('percent').innerText = perc + \" Completed\";\n        }\n\n        // আপনার দেওয়া ধাপগুলো টাইমার দিয়ে চালানো\n        async function runFakeSteps(repo, url) {\n            const steps = [\n                { p: 70, m: \"Deploying to Live...\" },\n                { p: 85, m: \"Conforming Site...\" },\n                { p: 95, m: \"Finalizing Server...\" }\n            ];\n\n            for (let step of steps) {\n                await new Promise(r => setTimeout(r, 10000)); // প্রতিটি ধাপে ১০ সেকেন্ড করে মোট ৩০ সেকেন্ড\n                updateProgress(step.p, step.m, step.p + \"%\");\n            }\n\n            // শেষ ধাপ: Successfully ✅\n            await new Promise(r => setTimeout(r, 5000)); \n            updateProgress(100, \"Successfully ✅\", \"100%\");\n            document.getElementById('loading-icon').classList.remove('spin');\n            \n            saveSite(repo, url);\n            setTimeout(() => location.reload(), 2000);\n        }\n\n        function saveSite(name, url) {\n            let sites = JSON.parse(localStorage.getItem('opendeta_v3')) || [];\n            sites.unshift({ name, url, time: new Date().toLocaleTimeString() });\n            localStorage.setItem('opendeta_v3', JSON.stringify(sites));\n        }\n\n        function loadSites() {\n            const list = document.getElementById('siteList');\n            let sites = JSON.parse(localStorage.getItem('opendeta_v3')) || [];\n            if (sites.length > 0) {\n                list.innerHTML = \"\";\n                sites.forEach((s, i) => {\n                    list.innerHTML += `\n                        <div class=\"bg-[#0d1117] p-5 rounded-2xl border border-[#30363d] flex justify-between items-center hover:border-[#00d1b2] transition group\">\n                            <div class=\"text-left\">\n                                <p class=\"font-bold text-[#00d1b2] text-lg\">${i+1}. ${s.name}</p>\n                                <p class=\"text-[9px] text-gray-500 font-mono tracking-widest uppercase\">${s.time}</p>\n                            </div>\n                            <a href=\"${s.url}\" target=\"_blank\" class=\"bg-[#00d1b2] text-black text-[11px] font-black px-6 py-2 rounded-lg hover:bg-white transition shadow-lg\">VISIT SITE</a>\n                        </div>`;\n                });\n            }\n        }\n\n        function clearHistory() {\n            if(confirm(\"Delete All History?\")) {\n                localStorage.removeItem('opendeta_v3');\n                location.reload();\n            }\n        }\n    </script>\n</body>\n</html>"}